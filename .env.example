# ── Copia este archivo como .env y rellena tus datos ──

# URL base de tu sitio WordPress (sin barra al final)
WP_URL=https://tusitio.com

# Usuario administrador de WordPress
WP_USER=admin

# Contraseña de Aplicación de WordPress
# Cómo generarla: WP Admin → Usuarios → Tu perfil → Contraseñas de aplicación
# Copia el valor con espacios tal cual lo genera WordPress
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Clave secreta del puente (debe ser idéntica a WP_MCP_SECRET en wp-config.php)
# Deja vacío si no la configuraste en el plugin
WP_MCP_SECRET=
